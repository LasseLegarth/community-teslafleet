# Local runtime config (root only) — may contain VIN / personal data.
# Anchored with a leading slash so it does NOT match ha-addon/config.yaml.
/config.yaml
/config.*.yaml
!/config.example.yaml
/templates/*.json
!/templates/*.example.json

# Secrets & runtime state — never commit
.env
/data/
/certs/
/proxy/
*.pem
*.key
cf.ini
client-secret
refresh_token
options.json
fleet-telemetry-config.json
!fleet-telemetry-config.example.json

# Build artifacts
/gateway
/dist/
*.test

# Editor/OS
.DS_Store
.idea/
.vscode/
