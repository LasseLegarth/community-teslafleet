# Copy to .env and fill in. Used by docker-compose.yml (standalone full stack).

# --- Telemetry endpoint (vehicles dial in here over TLS) ---
TELEMETRY_PORT=443                 # change if 443 is taken/blocked (e.g. 8443)
TELEMETRY_NAMESPACE=tesla_telemetry

# --- Your vehicle(s) + Home Assistant MQTT ---
TGW_VINS=5YJ3XXXXXXXXXXXXX         # comma-separated for multiple cars
TGW_HA_BROKER=tcp://192.168.1.10:1883
TGW_HA_USERNAME=mqtt
TGW_HA_PASSWORD=changeme
TGW_UNITS_SYSTEM=metric            # metric | imperial

# --- Profiles ---
TGW_FLEETAPI_ENABLED=true          # true if you run TeslaMate (else false for HA-only)
TGW_COMMANDS_ENABLED=true          # HA → car commands (needs onboarding token)

# --- Tesla app credentials (from developer.tesla.com; token via onboarding wizard) ---
TGW_TESLA_CLIENT_ID=
TGW_TESLA_CLIENT_SECRET=
TGW_TESLA_REFRESH_TOKEN=
TGW_TESLA_FLEET_API_URL=https://fleet-api.prd.eu.vn.cloud.tesla.com   # EU; NA: ...na.vn...
